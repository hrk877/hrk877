rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // ヘルパー関数
    // ========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (request.auth.token.firebase.sign_in_provider == 'password' || request.auth.token.admin == true);
    }

    // ========================================
    // ユーザー関連
    // ========================================
    
    match /users/{userId} {
      // ユーザー自身の情報のみ読み取り・書き込み可能
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
      
      match /habit_tracker/{trackerId} {
        allow read, write: if isOwner(userId) || isAdmin();
        
        match /logs/{logId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }
      
      match /training_records/{recordId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ========================================
    // システム関連 - 統計カウンタ
    // ========================================
    
    match /counters/user_count {
      // ユーザー数カウンタのみ、公開読み取りを許可
      allow read: if true;
      allow write: if isAdmin();
    }

    match /public_users/{userId} {
      // 統計・グラフ用の公開ユーザー情報（lastLoginAt等のみ）
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    match /whitelisted_users/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ========================================
    // 公開コンテンツ (artifacts)
    // ========================================
    
    match /artifacts/{appId}/public/data {
      
      match /banana_hand_posts/{postId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
      }

      match /museum_artworks/{artworkId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /posts/{postId} {
        allow read: if true;
        allow write: if isAdmin();
      }
      
      // Letters - 誰でも読み書き可能
      match /letters/{letterId} {
        allow read, write: if true;
      }
      
      // AI Logs - 誰でも読み書き可能
      match /ai_logs/{logId} {
        allow read, write: if true;
      }
    }
  }
}
